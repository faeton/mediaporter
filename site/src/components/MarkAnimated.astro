---
// Animated MediaPorter mark — draws the handoff path on load.
// Respects prefers-reduced-motion (global.css disables all anim).
interface Props { size?: number }
const { size = 280 } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 256 256" class="mp-mark" aria-hidden="true">
  <defs>
    <linearGradient id="mp-glow" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%"  stop-color="#F9A8D4"/>
      <stop offset="100%" stop-color="#EC4899"/>
    </linearGradient>
    <filter id="mp-soft" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="6"/>
    </filter>
  </defs>

  <!-- soft glow -->
  <g filter="url(#mp-soft)" opacity="0.45">
    <path d="M84 128 C 108 84, 132 172, 156 128"
          stroke="url(#mp-glow)" stroke-width="22" stroke-linecap="round" fill="none"/>
  </g>

  <!-- film card -->
  <rect x="28" y="56" width="56" height="144" rx="8" fill="#EC4899"/>
  <g fill="#0A0A0C">
    <rect x="36" y="64"  width="8" height="10" rx="2"/>
    <rect x="36" y="82"  width="8" height="10" rx="2"/>
    <rect x="36" y="100" width="8" height="10" rx="2"/>
    <rect x="36" y="118" width="8" height="10" rx="2"/>
    <rect x="36" y="136" width="8" height="10" rx="2"/>
    <rect x="36" y="154" width="8" height="10" rx="2"/>
    <rect x="36" y="172" width="8" height="10" rx="2"/>
    <rect x="68" y="64"  width="8" height="10" rx="2"/>
    <rect x="68" y="82"  width="8" height="10" rx="2"/>
    <rect x="68" y="100" width="8" height="10" rx="2"/>
    <rect x="68" y="118" width="8" height="10" rx="2"/>
    <rect x="68" y="136" width="8" height="10" rx="2"/>
    <rect x="68" y="154" width="8" height="10" rx="2"/>
    <rect x="68" y="172" width="8" height="10" rx="2"/>
  </g>

  <!-- iPad -->
  <rect x="156" y="40" width="80" height="176" rx="14" stroke="#EC4899" stroke-width="10" fill="none"/>

  <!-- M handoff path -->
  <path class="mp-path"
        d="M84 128 C 108 84, 132 172, 156 128"
        stroke="#EC4899" stroke-width="14" stroke-linecap="round" stroke-linejoin="round" fill="none"
        pathLength="100"
        stroke-dasharray="100" stroke-dashoffset="100"/>

  <!-- play triangle -->
  <path class="mp-play" d="M180 104 L 216 128 L 180 152 Z" fill="#EC4899"/>
</svg>

<style>
  .mp-mark { display: block; }
  .mp-path {
    animation: mp-draw 900ms var(--ease) 200ms forwards;
  }
  .mp-play {
    transform-origin: 198px 128px;
    opacity: 0;
    transform: scale(0.6);
    animation: mp-pop 320ms var(--ease) 1000ms forwards;
  }
  @keyframes mp-draw { to { stroke-dashoffset: 0; } }
  @keyframes mp-pop { to { opacity: 1; transform: scale(1); } }
</style>
