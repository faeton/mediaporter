---
import Base from "../layouts/Base.astro";
import MarkAnimated from "./MarkAnimated.astro";
import { type Locale, STRINGS, localizePath } from "../i18n/locales";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = STRINGS[locale];

// Render the lede with <strong> from translation as raw HTML (the strings are static, not user input).
const ledeHtml = t.heroLede;

// FAQ JSON-LD
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  inLanguage: locale,
  mainEntity: t.faq.map((q) => ({
    "@type": "Question",
    name: q.q,
    acceptedAnswer: { "@type": "Answer", text: q.a },
  })),
};

const changelogLink = `<a href="${localizePath(locale, "/changelog")}" class="link">${t.navChangelog.toLowerCase()}</a>`;
const featuresLedeHtml = t.featuresLede.replace("{changelog}", changelogLink);
---
<Base locale={locale} jsonLd={[faqLd]}>
  <!-- HERO -->
  <section class="hero section">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="md-tag accent">{t.heroEyebrow}</span>
        <h1>
          {t.heroTitleLead}
          <span class="accent">{t.heroTitleAccent}</span><br />
          <span class="muted">{t.heroTitleMuted}</span>
        </h1>
        <p class="lede" set:html={ledeHtml}></p>

        <div class="cta-row">
          <a href={localizePath(locale, "/") + "#download"} class="btn btn-primary">
            {t.ctaDownload}
            <span class="md-tag" style="background: rgba(10,10,12,0.15); border-color: transparent; color: #0A0A0C;">v0.3.2</span>
          </a>
          <a href="https://github.com/faeton/mediaporter" class="btn btn-ghost" rel="noopener">{t.ctaSource}</a>
        </div>

        <p class="md-comment">{t.heroRequires}</p>
      </div>

      <div class="hero-mark">
        <div class="mark-frame">
          <MarkAnimated size={320} />
        </div>
        <p class="caption md-comment">// film → handoff → device</p>
      </div>
    </div>

    <div class="container code-strip">
      <pre class="code">{t.heroOneLiner}</pre>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section" id="features">
    <div class="container">
      <header class="section-head">
        <span class="md-tag">## features</span>
        <h2>{t.featuresHeading}</h2>
        <p class="lede muted" set:html={featuresLedeHtml}></p>
      </header>

      <div class="feature-grid">
        {t.features.map((f) => (
          <article class="card feature">
            <span class="md-tag accent">{f.tag}</span>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="section" id="how">
    <div class="container how-grid">
      <div>
        <span class="md-tag">{t.howEyebrow}</span>
        <h2>{t.howHeading}</h2>
        <p class="muted lede">{t.howLede}</p>
      </div>
      <ol class="how-steps">
        {t.howSteps.map((s) => (
          <li>
            <span class="step">{s.n}</span>
            <div>
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- SETUP CALLOUT -->
  <section class="section" id="setup">
    <div class="container">
      <div class="card setup-callout">
        <span class="md-tag accent">{t.setupCalloutEyebrow}</span>
        <h2>{t.setupCalloutTitle}</h2>
        <p class="muted">{t.setupCalloutBody}</p>
        <div class="cta-row">
          <a href={localizePath(locale, "/setup")} class="btn btn-primary">{t.setupCalloutCta}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ANIME CALLOUT -->
  <section class="section" id="anime">
    <div class="container">
      <div class="card anime-callout">
        <span class="md-tag accent">{t.animeCalloutEyebrow}</span>
        <h2>{t.animeCalloutTitle}</h2>
        <p class="muted">{t.animeCalloutBody}</p>
        <div class="cta-row">
          <a href={localizePath(locale, "/guides/anime-on-iphone-and-ipad")} class="btn btn-primary">{t.animeCalloutCtaIphone}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MORE GUIDES -->
  <section class="section" id="guides">
    <div class="container">
      <header class="section-head">
        <span class="md-tag">{t.moreGuidesEyebrow}</span>
        <h2>{t.moreGuidesHeading}</h2>
      </header>
      <div class="guides-grid">
        {t.moreGuides.map((card) => (
          <a href={localizePath(locale, card.href)} class:list={["card guide-card", card.ctaSoon && "is-soon"]}>
            <div class="row-top">
              <span class="md-tag accent">{card.tag}</span>
              {card.ctaSoon && <span class="badge">{t.moreGuidesCtaSoon}</span>}
            </div>
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" id="faq">
    <div class="container">
      <header class="section-head">
        <span class="md-tag">{t.faqEyebrow}</span>
        <h2>{t.faqHeading}</h2>
      </header>
      <div class="faq-list">
        {t.faq.map((item) => (
          <details class="faq-item">
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- DOWNLOAD -->
  <section class="section download" id="download">
    <div class="container">
      <div class="card download-card">
        <span class="md-tag accent">{t.downloadEyebrow}</span>
        <h2>{t.downloadTitle}</h2>
        <p class="muted">{t.downloadBody}</p>

        <form class="email-form" action="mailto:hi@porter.md" method="post" enctype="text/plain">
          <input type="email" name="email" placeholder={t.downloadEmailPlaceholder} required aria-label="Email"/>
          <button type="submit" class="btn btn-primary">{t.downloadCta}</button>
        </form>

        <p class="md-comment">{t.downloadNote}</p>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero { padding-top: var(--sp-16); }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--sp-16);
    align-items: center;
  }
  @media (max-width: 880px) {
    .hero-grid { grid-template-columns: 1fr; gap: var(--sp-12); }
    .hero-mark { order: -1; display: flex; justify-content: center; }
  }
  .hero-copy h1 { margin-top: var(--sp-4); }
  .hero-copy h1 .accent { color: var(--accent); }
  .hero-copy h1 .muted { color: var(--text-2); font-weight: 600; }
  .lede {
    margin-top: var(--sp-6);
    font-size: 1.1875rem;
    color: var(--text-2);
    max-width: 56ch;
  }
  .lede.muted { color: var(--text-2); }
  .lede :global(strong) { color: var(--text); }
  .cta-row {
    display: flex; flex-wrap: wrap; gap: var(--sp-3);
    margin-top: var(--sp-8);
  }

  .hero-mark { display: flex; flex-direction: column; align-items: center; gap: var(--sp-4); }
  .mark-frame {
    width: 360px; max-width: 100%;
    aspect-ratio: 1;
    border-radius: var(--r-lg);
    background:
      radial-gradient(120% 120% at 30% 20%, rgba(236, 72, 153, 0.18), transparent 55%),
      var(--surface);
    border: 1px solid var(--border);
    display: grid; place-items: center;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.03),
      0 30px 60px -30px rgba(236, 72, 153, 0.35);
  }
  .caption { margin: 0; }

  .code-strip { margin-top: var(--sp-12); }

  .section-head {
    display: flex; flex-direction: column; gap: var(--sp-3);
    margin-bottom: var(--sp-12); max-width: 64ch;
  }
  .muted { color: var(--text-2); }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }
  @media (max-width: 880px) { .feature-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .feature-grid { grid-template-columns: 1fr; } }
  .feature h3 { margin-block: var(--sp-3) var(--sp-2); }
  .feature p { color: var(--text-2); }

  .how-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: var(--sp-16);
  }
  @media (max-width: 880px) { .how-grid { grid-template-columns: 1fr; gap: var(--sp-8); } }
  .how-steps { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--sp-6); }
  .how-steps li { display: grid; grid-template-columns: auto 1fr; gap: var(--sp-6); align-items: start; }
  .how-steps .step {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--accent);
    padding: 6px 10px;
    border: 1px solid color-mix(in srgb, var(--accent) 35%, var(--border));
    border-radius: var(--r-sm);
    background: var(--code-bg);
  }
  .how-steps h3 { margin-bottom: var(--sp-2); }
  .how-steps p { color: var(--text-2); }

  .guides-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }
  @media (max-width: 880px) { .guides-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .guides-grid { grid-template-columns: 1fr; } }
  .guide-card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    color: var(--text);
    text-decoration: none;
    transition: transform var(--dur-fast) var(--ease), border-color var(--dur-fast) var(--ease);
  }
  .guide-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--accent) 45%, var(--border));
  }
  .guide-card .row-top { display: flex; align-items: center; justify-content: space-between; gap: var(--sp-2); }
  .guide-card h3 { margin: 0; }
  .guide-card p { color: var(--text-2); margin: 0; }
  .guide-card.is-soon { opacity: 0.86; }
  .badge {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-3);
    padding: 2px 8px;
    border: 1px dashed var(--border);
    border-radius: 999px;
  }

  .setup-callout { padding-block: var(--sp-10); text-align: center; }
  .setup-callout h2 { margin-block: var(--sp-3) var(--sp-4); max-width: 28ch; margin-inline: auto; }
  .setup-callout .muted { max-width: 60ch; margin-inline: auto; }
  .setup-callout .cta-row { justify-content: center; }

  .anime-callout { text-align: center; padding-block: var(--sp-12); }
  .anime-callout h2 { margin-block: var(--sp-3) var(--sp-4); }
  .anime-callout .muted { max-width: 60ch; margin-inline: auto; }
  .anime-callout .cta-row { justify-content: center; }

  .faq-list { display: flex; flex-direction: column; gap: var(--sp-3); }
  .faq-item {
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    background: var(--surface);
    padding: var(--sp-3) var(--sp-4);
  }
  .faq-item summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--text);
    list-style: none;
    position: relative;
    padding-right: var(--sp-6);
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after {
    content: "+";
    position: absolute; right: 0; top: 0;
    color: var(--accent);
    font-family: var(--font-mono);
    font-weight: 400;
  }
  .faq-item[open] summary::after { content: "−"; }
  .faq-item p { color: var(--text-2); margin-top: var(--sp-3); }

  .download-card { text-align: center; padding-block: var(--sp-12); }
  .download-card h2 { margin-block: var(--sp-3) var(--sp-4); }
  .download-card .muted { max-width: 52ch; margin-inline: auto; }
  .email-form {
    display: flex; gap: var(--sp-2);
    max-width: 460px; margin: var(--sp-8) auto var(--sp-3);
    flex-wrap: wrap; justify-content: center;
  }
  .email-form input {
    flex: 1; min-width: 220px;
    padding: 12px 14px;
    border-radius: var(--r-sm);
    border: 1px solid var(--border);
    background: var(--code-bg);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.9375rem;
  }
  .email-form input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 25%, transparent);
  }
</style>
