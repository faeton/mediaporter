---
import {
  type Locale,
  DEFAULT_LOCALE,
  LOCALES,
  LOCALE_LABEL,
  HTML_LANG,
  STRINGS,
  localizePath,
  stripLocale,
} from "../i18n/locales";

interface Props {
  locale?: Locale;
}

const { locale = DEFAULT_LOCALE } = Astro.props;
const t = STRINGS[locale];

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const basePath = stripLocale(path);

const links: { href: string; label: string }[] = [
  { href: localizePath(locale, "/guides/anime-on-iphone-and-ipad"), label: t.navGuides },
  { href: localizePath(locale, "/setup"), label: t.navSetup },
  { href: localizePath(locale, "/changelog"), label: t.navChangelog },
  { href: localizePath(locale, "/support"), label: t.navSupport },
  { href: localizePath(locale, "/privacy"), label: t.navPrivacy },
];
---
<header class="site-header">
  <div class="container row">
    <a href={localizePath(locale, "/")} class="brand" aria-label="MediaPorter home">
      <svg width="28" height="28" viewBox="0 0 256 256" aria-hidden="true">
        <rect x="28" y="56" width="56" height="144" rx="8" fill="#EC4899"/>
        <path d="M84 128 C 108 84, 132 172, 156 128"
              stroke="#EC4899" stroke-width="14" stroke-linecap="round" fill="none"/>
        <rect x="156" y="40" width="80" height="176" rx="14" stroke="#EC4899" stroke-width="10" fill="none"/>
        <path d="M180 104 L 216 128 L 180 152 Z" fill="#EC4899"/>
      </svg>
      <span class="wordmark"><span>Media</span><span class="accent">Porter</span><span class="tld">.md</span></span>
    </a>

    <nav aria-label="Primary">
      <ul>
        {links.map((l) => (
          <li>
            <a href={l.href} class:list={["nav-link", path === l.href.replace(/\/$/, "") && "is-active"]}>{l.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="lang-switch" aria-label="Language">
      {LOCALES.map((l) => (
        <a
          href={localizePath(l, basePath)}
          hreflang={HTML_LANG[l]}
          class:list={["lang", l === locale && "is-active"]}
          aria-current={l === locale ? "true" : undefined}
        >{LOCALE_LABEL[l]}</a>
      ))}
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--bg) 80%, transparent);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--border);
  }
  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--sp-3);
    gap: var(--sp-4);
  }
  .brand { display: inline-flex; align-items: center; gap: var(--sp-3); color: var(--text); }
  .wordmark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.125rem;
    letter-spacing: -0.01em;
  }
  .wordmark .accent { color: var(--accent); }
  .wordmark .tld {
    color: var(--text-3);
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 0.9rem;
    margin-left: 2px;
  }
  nav ul { display: flex; gap: var(--sp-6); list-style: none; padding: 0; margin: 0; }
  .nav-link {
    color: var(--text-2);
    font-size: 0.9375rem;
    transition: color var(--dur-fast) var(--ease);
  }
  .nav-link:hover, .nav-link.is-active { color: var(--text); }

  .lang-switch {
    display: flex;
    gap: var(--sp-2);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }
  .lang {
    color: var(--text-3);
    padding: 2px 6px;
    border-radius: var(--r-sm);
    transition: color var(--dur-fast) var(--ease), background var(--dur-fast) var(--ease);
  }
  .lang:hover { color: var(--text-2); }
  .lang.is-active {
    color: var(--text);
    background: var(--code-bg);
    border: 1px solid var(--border);
  }

  @media (max-width: 760px) {
    .row { flex-wrap: wrap; }
    nav { order: 3; width: 100%; }
    .lang-switch { order: 2; }
  }
  @media (max-width: 560px) {
    nav ul { gap: var(--sp-4); flex-wrap: wrap; }
    .wordmark .tld { display: none; }
  }
</style>
