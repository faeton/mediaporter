---
import { type Locale, DEFAULT_LOCALE, STRINGS, localizePath } from "../i18n/locales";

interface Props {
  locale?: Locale;
}
const { locale = DEFAULT_LOCALE } = Astro.props;
const t = STRINGS[locale];
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="grid">
      <div>
        <div class="lockup">
          <span class="word">MediaPorter</span>
          <span class="tld">.md</span>
        </div>
        <p class="tagline md-comment">{t.footerTagline}</p>
      </div>
      <nav aria-label="Footer">
        <h4>{t.footerProduct}</h4>
        <ul>
          <li><a href={localizePath(locale, "/") + "#features"}>{t.footerFeatures}</a></li>
          <li><a href={localizePath(locale, "/guides/anime-on-iphone-and-ipad")}>{t.navGuides}</a></li>
          <li><a href={localizePath(locale, "/setup")}>{t.navSetup}</a></li>
          <li><a href={localizePath(locale, "/changelog")}>{t.navChangelog}</a></li>
        </ul>
      </nav>
      <nav aria-label="Footer">
        <h4>{t.footerHelp}</h4>
        <ul>
          <li><a href={localizePath(locale, "/support")}>{t.navSupport}</a></li>
          <li><a href={localizePath(locale, "/privacy")}>{t.navPrivacy}</a></li>
        </ul>
      </nav>
    </div>
    <div class="base">
      <span class="md-comment">// {t.footerRights.replace("{year}", String(year))}</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    padding-block: var(--sp-12);
    margin-top: var(--sp-24);
    color: var(--text-2);
  }
  .grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: var(--sp-12);
    align-items: start;
  }
  @media (max-width: 720px) {
    .grid { grid-template-columns: 1fr 1fr; gap: var(--sp-8); }
  }
  .lockup { font-family: var(--font-display); font-weight: 700; font-size: 1.25rem; color: var(--text); }
  .lockup .tld { color: var(--text-3); font-family: var(--font-mono); font-weight: 400; font-size: 1rem; }
  .tagline { margin-top: var(--sp-2); }
  h4 { font-family: var(--font-mono); font-size: 0.8125rem; font-weight: 500; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.06em; margin: 0 0 var(--sp-3); }
  ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--sp-2); }
  ul a { color: var(--text-2); }
  ul a:hover { color: var(--text); }
  .base { margin-top: var(--sp-12); padding-top: var(--sp-6); border-top: 1px solid var(--border); }
</style>
